# GitHub App Configuration
# See README.md for setup instructions

# Your GitHub App ID
GITHUB_APP_ID=

# Your GitHub App private key (replace \n with actual newlines or use quotes)
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
...
-----END RSA PRIVATE KEY-----"

# Your webhook secret (generate with: openssl rand -hex 32)
GITHUB_WEBHOOK_SECRET=

# Server port (optional, default: 3000)
PORT=3000
