  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "ts-node src/app.ts",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "analyze": "ts-node src/cli.ts"
  },
  "keywords": [
    "security",
    "ai-agents",
    "static-analysis",
    "github-app",
    "langchain",
    "crewai",
    "afb"
