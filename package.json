{
  "name": "wyscan",
  "version": "1.0.0",
  "description": "Agent Failure Boundary Scanner - Detects AFB04 (Unauthorized Action) boundaries in agentic AI codebases through static analysis",
  "main": "dist/app.js",
  "bin": {
    "wyscan": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "link": "npm run build && npm link",
    "start": "node dist/app.js",
    "dev": "npx ts-node src/app.ts",
    "lint": "npx eslint src/**/*.ts",
    "test": "npx jest",
    "wyscan": "npx ts-node src/cli/index.ts"
  },
  "keywords": [
    "security",
    "ai-agents",
    "static-analysis",
    "github-app",
    "langchain",
    "crewai",
    "afb"
  ],
  "author": "Plarix Security",
  "license": "Apache-2.0",
  "dependencies": {
    "@octokit/auth-app": "^6.0.3",
    "@octokit/rest": "^20.0.2",
    "@octokit/webhooks": "^12.0.10",
    "chalk": "^4.1.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "simple-git": "^3.22.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.22.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.10",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
